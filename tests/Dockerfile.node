FROM node:22-slim

WORKDIR /workspace
ENV NODE_PATH=/opt/containerbox/node_modules

RUN mkdir -p /opt/containerbox/node_modules/slugify-mini \
    && printf '%s\n' \
    "exports.slug = (value) => String(value).trim().toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');" \
    > /opt/containerbox/node_modules/slugify-mini/index.js
